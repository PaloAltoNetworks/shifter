# Django settings (required)
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Site URL for provisioner callbacks (required)
SITE_URL=http://localhost:8000

# Database (required)
DB_NAME=shifter
DB_USER=postgres
DB_PASSWORD=your-password-here
DB_PORT=5432

# Guacamole Database (created automatically on first postgres startup)
GUACAMOLE_DB_NAME=guacamole
GUACAMOLE_DB_USER=guacamole_admin
GUACAMOLE_DB_PASSWORD=guac-local-password

# Local Provisioner (optional - for full local dev)
# Set to "subprocess" to run provisioner locally instead of ECS
# Requires: Pulumi CLI, AWS credentials, and provisioner env vars
# LOCAL_PROVISIONER=subprocess
# PROVISIONER_PATH=/path/to/shifter/engine/provisioner
# PULUMI_BACKEND_URL=s3://your-pulumi-state-bucket
# PULUMI_SECRETS_PROVIDER=awskms://alias/dev-range-pulumi-secrets
