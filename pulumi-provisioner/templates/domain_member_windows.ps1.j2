<powershell>
# Windows Domain Member setup script
# This runs during instance boot via EC2 user data
#
# This instance joins an existing AD domain. The DC must be ready first.
#
# Template variables:
#   hostname              - Computer name for this workstation
#   public_key            - SSH public key for Administrator access
#   dc_config_param_name  - SSM Parameter Store path for DC config
#   presigned_url         - Pre-signed URL for XDR agent installer (optional)
#   agent_s3_key          - S3 key for agent installer (for logging)

$ErrorActionPreference = "Stop"
$LogFile = "C:\Windows\Temp\domain-member-setup.log"

function Log-Message {
    param([string]$Message)
    $timestamp = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
    "$timestamp - $Message" | Out-File -FilePath $LogFile -Append
    Write-Host $Message
}

try {
    Log-Message "Starting Windows Domain Member setup..."

    # --------------------------------------------------------------------------
    # 1. Set hostname
    # --------------------------------------------------------------------------
    Log-Message "Setting hostname to {{ hostname }}..."
    Rename-Computer -NewName "{{ hostname }}" -Force
    Log-Message "Hostname set (will apply after domain join reboot)"

    # --------------------------------------------------------------------------
    # 2. Configure OpenSSH Server for Terminal UI access
    # --------------------------------------------------------------------------
    Log-Message "Configuring OpenSSH Server..."
    Start-Service sshd
    Set-Service -Name sshd -StartupType Automatic

    # Set up SSH key authentication for Administrator
    {% if public_key %}
    Log-Message "Setting up SSH key authentication..."
    $sshDir = "C:\ProgramData\ssh"
    if (!(Test-Path $sshDir)) { New-Item -ItemType Directory -Path $sshDir -Force }
    "{{ public_key }}" | Out-File -Encoding ascii "$sshDir\administrators_authorized_keys"
    icacls "$sshDir\administrators_authorized_keys" /inheritance:r /grant "Administrators:F" /grant "SYSTEM:F"
    Log-Message "SSH key authentication configured"
    {% endif %}

    # --------------------------------------------------------------------------
    # 3. Read DC configuration from SSM Parameter Store
    # --------------------------------------------------------------------------
    Log-Message "Reading DC configuration from SSM Parameter Store..."
    Log-Message "Parameter: {{ dc_config_param_name }}"

    # Get AWS region from instance metadata
    $Region = Invoke-RestMethod -Uri http://169.254.169.254/latest/meta-data/placement/region

    # Retry loop - DC might not be fully ready yet
    $maxAttempts = 30
    $attempt = 0
    $DcConfig = $null

    while ($attempt -lt $maxAttempts) {
        try {
            $attempt++
            Log-Message "Attempting to read DC config (attempt $attempt/$maxAttempts)..."

            $paramResult = aws ssm get-parameter `
                --name "{{ dc_config_param_name }}" `
                --with-decryption `
                --region $Region `
                --output json 2>&1

            if ($LASTEXITCODE -eq 0) {
                $param = $paramResult | ConvertFrom-Json
                $DcConfig = $param.Parameter.Value | ConvertFrom-Json

                # Verify DC config has required fields
                if ($DcConfig.domain_name -and $DcConfig.dc_ip -and $DcConfig.domain_admin_password) {
                    Log-Message "DC config retrieved successfully"
                    Log-Message "Domain: $($DcConfig.domain_name)"
                    Log-Message "DC IP: $($DcConfig.dc_ip)"
                    break
                } else {
                    Log-Message "DC config incomplete, waiting for DC to finish setup..."
                    $DcConfig = $null
                }
            } else {
                Log-Message "SSM parameter not ready yet..."
            }
        } catch {
            Log-Message "Error reading DC config: $_"
        }

        Start-Sleep -Seconds 10
    }

    if (-not $DcConfig) {
        throw "Failed to retrieve DC configuration after $maxAttempts attempts"
    }

    # --------------------------------------------------------------------------
    # 4. Configure DNS to point to DC
    # --------------------------------------------------------------------------
    Log-Message "Configuring DNS to point to Domain Controller..."

    # Get the primary network adapter
    $adapter = Get-NetAdapter | Where-Object { $_.Status -eq "Up" -and $_.InterfaceDescription -notlike "*Loopback*" } | Select-Object -First 1

    if ($adapter) {
        # Set DNS to DC IP (primary) and AWS VPC DNS (secondary)
        Set-DnsClientServerAddress -InterfaceIndex $adapter.InterfaceIndex -ServerAddresses @($DcConfig.dc_ip, "169.254.169.253")
        Log-Message "DNS configured: Primary=$($DcConfig.dc_ip), Secondary=169.254.169.253"
    } else {
        Log-Message "WARNING: Could not find network adapter for DNS configuration"
    }

    # --------------------------------------------------------------------------
    # 5. Schedule post-reboot agent installation (if agent URL provided)
    # --------------------------------------------------------------------------
    {% if presigned_url %}
    Log-Message "Setting up post-reboot agent installation..."

    $PostRebootScript = @"

`$ErrorActionPreference = "Stop"
`$LogFile = "C:\Windows\Temp\domain-member-setup.log"

function Log-Message {
    param([string]`$Message)
    `$timestamp = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
    "`$timestamp - `$Message" | Out-File -FilePath `$LogFile -Append
    Write-Host `$Message
}

try {
    Log-Message "Post-reboot agent installation starting..."

    # Wait a moment for domain services to be fully available
    Start-Sleep -Seconds 30

    # Download agent installer
    Log-Message "Downloading XDR agent installer..."
    `$InstallerPath = "C:\Windows\Temp\agent-installer"
    `$ProgressPreference = 'SilentlyContinue'
    Invoke-WebRequest -Uri '{{ presigned_url }}' -OutFile `$InstallerPath -UseBasicParsing

    # Detect file type and install
    Log-Message "Installing XDR agent..."
    `$filename = "{{ agent_s3_key }}"

    switch -Regex (`$filename) {
        '\.msi$' {
            Log-Message "Installing via MSI..."
            Start-Process msiexec.exe -ArgumentList "/i ```"`$InstallerPath```" /quiet /norestart" -Wait -NoNewWindow
        }
        '\.exe$' {
            Log-Message "Installing via EXE..."
            Start-Process -FilePath `$InstallerPath -ArgumentList "/S", "/v/quiet" -Wait -NoNewWindow
        }
        '\.zip$' {
            Log-Message "Extracting ZIP archive..."
            `$ExtractPath = "C:\Windows\Temp\agent-extract"
            Expand-Archive -Path `$InstallerPath -DestinationPath `$ExtractPath -Force

            `$installer = Get-ChildItem -Path `$ExtractPath -Recurse -Include "*.msi","*.exe" | Select-Object -First 1
            if (`$installer) {
                Log-Message "Found installer: `$(`$installer.FullName)"
                if (`$installer.Extension -eq ".msi") {
                    Start-Process msiexec.exe -ArgumentList "/i ```"`$(`$installer.FullName)```" /quiet /norestart" -Wait -NoNewWindow
                } else {
                    Start-Process -FilePath `$installer.FullName -ArgumentList "/S", "/v/quiet" -Wait -NoNewWindow
                }
            } else {
                Log-Message "ERROR: No installer found in archive"
            }
        }
        default {
            Log-Message "Unknown installer type, attempting to run as executable..."
            Start-Process -FilePath `$InstallerPath -ArgumentList "/S" -Wait -NoNewWindow
        }
    }

    Log-Message "XDR agent installation complete"

    # Remove the scheduled task
    Unregister-ScheduledTask -TaskName "DomainMember-PostRebootAgent" -Confirm:`$false -ErrorAction SilentlyContinue

    Log-Message "Post-reboot configuration complete!"

} catch {
    Log-Message "ERROR in post-reboot script: `$_"
    throw
}
"@

    # Save post-reboot script
    $PostRebootScript | Out-File -FilePath "C:\Windows\Temp\domain-member-post-reboot.ps1" -Encoding UTF8

    # Create scheduled task to run post-reboot script
    Log-Message "Creating post-reboot scheduled task..."
    $Action = New-ScheduledTaskAction -Execute "powershell.exe" -Argument "-ExecutionPolicy Bypass -File C:\Windows\Temp\domain-member-post-reboot.ps1"
    $Trigger = New-ScheduledTaskTrigger -AtStartup
    $Principal = New-ScheduledTaskPrincipal -UserId "SYSTEM" -LogonType ServiceAccount -RunLevel Highest
    $Settings = New-ScheduledTaskSettingsSet -AllowStartIfOnBatteries -DontStopIfGoingOnBatteries -StartWhenAvailable
    Register-ScheduledTask -TaskName "DomainMember-PostRebootAgent" -Action $Action -Trigger $Trigger -Principal $Principal -Settings $Settings -Force

    Log-Message "Post-reboot agent installation scheduled"
    {% else %}
    Log-Message "No agent installer configured - skipping XDR agent installation"
    {% endif %}

    # --------------------------------------------------------------------------
    # 6. Join the domain
    # --------------------------------------------------------------------------
    Log-Message "Joining domain: $($DcConfig.domain_name)..."

    # Create credential for domain join
    $SecurePassword = ConvertTo-SecureString $DcConfig.domain_admin_password -AsPlainText -Force
    $DomainCredential = New-Object System.Management.Automation.PSCredential (
        "$($DcConfig.netbios_name)\Administrator",
        $SecurePassword
    )

    # Join the domain - this will trigger a reboot
    Add-Computer `
        -DomainName $DcConfig.domain_name `
        -Credential $DomainCredential `
        -Restart `
        -Force

    # Note: Server will reboot here, post-reboot script will install agent

} catch {
    Log-Message "ERROR: $_"
    throw
}
</powershell>
