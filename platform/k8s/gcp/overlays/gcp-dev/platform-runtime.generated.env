# platform-runtime.generated.env — PLACEHOLDER for OSS deployers.
#
# This file is the configMapGenerator input referenced by the gcp-dev
# overlay's kustomization.yaml. It is generated per-deploy by
# scripts/gcp/render_runtime_env.py from terraform outputs and overwrites
# whatever is in the working copy.
#
# The values below are intentionally placeholder / fail-loud — they keep
# `kustomize build` working for static validation (CI, kubeconform,
# kube-linter) without baking real deployment identifiers into the repo.
# Before deploying, run the renderer:
#
#   python3 scripts/gcp/render_runtime_env.py \
#     --terraform-output-json /tmp/gcp-terraform-outputs.json \
#     --output platform/k8s/gcp/overlays/<env>/platform-runtime.generated.env
STORAGE_BUCKET_NAME=REPLACE_AT_DEPLOY
AGENT_STORAGE_BUCKET=REPLACE_AT_DEPLOY
TF_STATE_BUCKET=REPLACE_AT_DEPLOY
RANGE_EVENTS_TOPIC_ID=REPLACE_AT_DEPLOY
QUEUE_CMS_CONSUMER_ID=REPLACE_AT_DEPLOY
QUEUE_CMS_PUBLISHER_ID=REPLACE_AT_DEPLOY
QUEUE_ENGINE_CONSUMER_ID=REPLACE_AT_DEPLOY
QUEUE_ENGINE_PUBLISHER_ID=REPLACE_AT_DEPLOY
QUEUE_MC_CONSUMER_ID=REPLACE_AT_DEPLOY
QUEUE_MC_PUBLISHER_ID=REPLACE_AT_DEPLOY
QUEUE_EXPERIMENTS_CONSUMER_ID=REPLACE_AT_DEPLOY
QUEUE_EXPERIMENTS_PUBLISHER_ID=REPLACE_AT_DEPLOY
DB_SECRET_ID=REPLACE_AT_DEPLOY
APP_SECRET_ID=REPLACE_AT_DEPLOY
GUACAMOLE_SECRET_ID=REPLACE_AT_DEPLOY
GDC_ACCESS_SECRET_ID=REPLACE_AT_DEPLOY
DJANGO_DEBUG=false
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
DB_HOST=REPLACE_AT_DEPLOY
DB_PORT=5432
REDIS_HOST=REPLACE_AT_DEPLOY
REDIS_PORT=6379
DJANGO_ALLOWED_HOSTS=REPLACE_AT_DEPLOY
DJANGO_CSRF_TRUSTED_ORIGINS=REPLACE_AT_DEPLOY
SITE_URL=REPLACE_AT_DEPLOY
GUACAMOLE_BASE_URL=/guacamole
GUACAMOLE_API_BASE_URL=http://guacamole-client.shifter-platform.svc.cluster.local:8080/guacamole
GUACAMOLE_POSTGRESQL_HOSTNAME=REPLACE_AT_DEPLOY
GUACAMOLE_POSTGRESQL_PORT=5432
GDC_VM_IMAGE_GCS_SECRET_ID=REPLACE_AT_DEPLOY
GDC_VMSERIES_IMAGE_GCS_SECRET_ID=REPLACE_AT_DEPLOY
GDC_VMSERIES_BOOTSTRAP_XML_TEMPLATE_SECRET_ID=
