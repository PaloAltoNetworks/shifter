# platform-runtime.generated.env
#
# Deploy-time generated input for the gcp-dev platform-runtime ConfigMap.
# The GCP deploy workflow overwrites this file from live Terraform outputs
# before running `kubectl apply -k`.
#
# Generate it manually with an immutable image tag:
#
#   python3 scripts/gcp/render_runtime_env.py \
#     --terraform-output-json /tmp/gcp-terraform-outputs.json \
#     --image-tag "$SHORT_SHA" \
#     --output platform/k8s/gcp/overlays/gcp-dev/platform-runtime.generated.env
#
# Keep this tracked stub comment-only. Do not commit deployment-specific
# generated values here.
