{
  "name": "mcp-shifter",
  "version": "0.1.0",
  "description": "MCP server for Shifter - HTTP transport with per-user Kali routing",
  "type": "module",
  "main": "build/index.js",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf build",
    "start": "node build/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "docker:build": "docker build -t mcp-shifter .",
    "docker:run": "docker run -p 3001:3001 --env-file .env mcp-shifter"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.699.0",
    "@aws-sdk/rds-signer": "^3.699.0",
    "@modelcontextprotocol/sdk": "^1.24.3",
    "aptl-mcp-common": "file:../aptl-mcp-common",
    "aws-jwt-verify": "^4.0.1",
    "express": "^4.21.2",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
