# Django settings
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000

# Database (for local dev, docker-compose provides these)
DB_HOST=db
DB_PORT=5432
DB_NAME=shifter
DB_USER=postgres
DB_PASSWORD=postgres

# Gunicorn (optional, defaults shown)
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=30
