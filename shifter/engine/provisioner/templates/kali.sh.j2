#!/bin/bash
set -euo pipefail

# Log output
exec > >(tee /var/log/user-data.log) 2>&1
echo "Starting Kali headless setup..."

# Issue #762: the per-instance Kali desktop password is set by the
# engine provisioner via SSH (using the per-instance SSH key already
# baked into authorized_keys below) after this VM reaches a reachable
# state — not in user_data. The password value never appears in the
# rendered cloud-init payload. See
# shifter/engine/provisioner/plans/set_local_password_plan.py.

# Ensure the packages needed for SSH/RDP access exist on the VM Runtime image
if command -v apt-get >/dev/null 2>&1; then
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y openssh-server xrdp xorgxrdp || apt-get install -y openssh-server xrdp
fi

# Set hostname for XDR console visibility
echo "Setting hostname to {{ hostname }}..."
hostnamectl set-hostname {{ hostname }}
echo "127.0.0.1 {{ hostname }}" >> /etc/hosts
echo "Hostname set"

# Configure SSH access for MCP server
echo "Configuring SSH access..."
mkdir -p /home/kali/.ssh
chmod 700 /home/kali/.ssh
echo "{{ public_key }}" >> /home/kali/.ssh/authorized_keys
chmod 600 /home/kali/.ssh/authorized_keys
chown -R kali:kali /home/kali/.ssh
echo "SSH access configured"

# Ensure SSH password auth is enabled for tooling that expects local login
if [ -f /etc/ssh/sshd_config ]; then
    sed -i 's/^#\?PasswordAuthentication .*/PasswordAuthentication yes/' /etc/ssh/sshd_config || true
    if ! grep -q '^PasswordAuthentication yes' /etc/ssh/sshd_config; then
        echo 'PasswordAuthentication yes' >> /etc/ssh/sshd_config
    fi
fi

# Ensure SSH service is running
if systemctl list-unit-files | grep -q "^ssh.service"; then
    systemctl enable --now ssh || true
elif systemctl list-unit-files | grep -q "^sshd.service"; then
    systemctl enable --now sshd || true
fi

# Ensure xrdp is running for RDP access via Guacamole
if systemctl list-unit-files | grep -q "^xrdp.service"; then
    echo "Starting xrdp service..."
    systemctl enable --now xrdp || true
    systemctl status xrdp --no-pager || true
    echo "xrdp service started"
fi

echo "Kali setup complete"
