# Node modules - rebuilt in container
**/node_modules

# Build outputs - rebuilt in container
**/build
**/dist

# Development files
**/.git
**/.gitignore
**/*.md
**/LICENSE

# Test files
**/tests
**/*.test.ts
**/*.spec.ts
**/coverage
**/.nyc_output

# IDE and editor files
**/.vscode
**/.idea
**/*.swp
**/*.swo

# OS files
**/.DS_Store
**/Thumbs.db

# Environment files (should not be in image)
**/.env
**/.env.*

# Other MCP servers not needed for mcp-shifter
mcp-red
