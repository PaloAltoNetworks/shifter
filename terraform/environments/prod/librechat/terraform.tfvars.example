# LibreChat Environment Configuration
# Copy to terraform.tfvars and fill in values

environment = "prod"
aws_region  = "us-east-2"

# LibreChat subnet within Portal VPC
# Must not conflict with existing subnets - check AWS console
subnet_cidr = "10.0.X.0/24"

# EC2 Configuration
instance_type    = "t3.small"
root_volume_size = 30
data_volume_size = 50

# LibreChat Configuration
app_title          = "Shifter Chat"
allow_registration = true # Set to false after creating admin account

tags = {
  Project     = "shifter"
  Environment = "prod"
  Component   = "librechat"
  ManagedBy   = "terraform"
}
