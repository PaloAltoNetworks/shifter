CLOUD_PROVIDER=gcp
ENVIRONMENT=gcp-dev
CLOUD_REGION=us-central1
GCP_REGION=us-central1
GCP_PROJECT_ID=shifter-gcp-dev
GOOGLE_CLOUD_PROJECT=shifter-gcp-dev
ENGINE_TASK_NAMESPACE=shifter-jobs
ENGINE_TASK_SERVICE_ACCOUNT_NAME=provisioner
ENGINE_TASK_IMAGE_PULL_POLICY=Always
GDC_VM_STORAGE_CLASS=local-shared
GDC_VM_IMAGE_GCS_SECRET_ID=shifter-gcp-dev-gdc-vm-image-gcs
# Palo Alto VM-Series on GDC VM Runtime. The image URL for VM-Series is no
# longer configured here; it is fetched at NGFW provisioning time from
# Secret Manager (shifter-gcp-dev-range-image-vmseries) via
# main.get_gdc_image_url, matching the AWS SSM-backed AMI contract.
GDC_VMSERIES_BOOTSTRAP_BUCKET=
GDC_VMSERIES_STORAGE_CLASS=local-shared
GDC_VMSERIES_IMAGE_GCS_SECRET_ID=shifter-gcp-dev-gdc-vm-image-gcs
GDC_VMSERIES_NAMESPACE_PREFIX=ngfw
GDC_VMSERIES_MGMT_NETWORK_NAME=pod-network
GDC_VMSERIES_MGMT_IP_CIDR=
GDC_VMSERIES_DATA_NETWORK_NAME=
GDC_VMSERIES_DATA_IP_CIDR=
GDC_VMSERIES_ROUTE_NEXT_HOP_IP=
GDC_VMSERIES_VCPUS=4
GDC_VMSERIES_MEMORY=8Gi
GDC_VMSERIES_DISK_SIZE_GIB=81
GDC_VMSERIES_BOOTSTRAP_DISK_SIZE_GIB=1
GDC_VMSERIES_BOOTSTRAP_XML_TEMPLATE_SECRET_ID=
# Guest access defaults for VM Runtime assets.
GDC_WINDOWS_ADMIN_PASSWORD=CortexSavesTheDay!
GDC_KALI_PASSWORD=kali
GDC_UBUNTU_PASSWORD=ubuntu
# Per-guest sizing only. Image URLs are fetched live from Secret Manager at
# range-create time (shifter-gcp-dev-range-image-<kali|ubuntu|windows|dc>).
GDC_KALI_VCPUS=2
GDC_KALI_MEMORY=4Gi
GDC_KALI_DISK_SIZE_GIB=20
GDC_UBUNTU_VCPUS=1
GDC_UBUNTU_MEMORY=2Gi
GDC_UBUNTU_DISK_SIZE_GIB=20
GDC_WINDOWS_VCPUS=2
GDC_WINDOWS_MEMORY=8Gi
GDC_WINDOWS_DISK_SIZE_GIB=64
GDC_DC_VCPUS=2
GDC_DC_MEMORY=8Gi
GDC_DC_DISK_SIZE_GIB=64
# Lower-fidelity scenario Pod assets must use explicitly curated container
# images. No Docker Hub defaults are shipped in the runtime contract.
GDC_SCENARIO_POD_IMAGE_PULL_POLICY=IfNotPresent
GDC_SCENARIO_POD_KALI_IMAGE=
GDC_SCENARIO_POD_UBUNTU_IMAGE=
