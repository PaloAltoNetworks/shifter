{
  "mcpServers": {
    "shifter-db": {
      "command": "node",
      "args": ["mcp/shifter-db/index.js"],
      "env": {
        "PANW_SHIFTER_DEV_PROFILE": "panw-shifter-dev-workstation",
        "PANW_SHIFTER_PROD_PROFILE": "panw-shifter-prod-workstation"
      }
    },
    "shifter-ngfw": {
      "command": "node",
      "args": ["mcp/ngfw/index.js"],
      "env": {
        "PANW_SHIFTER_DEV_PROFILE": "panw-shifter-dev-workstation",
        "PANW_SHIFTER_PROD_PROFILE": "panw-shifter-prod-workstation"
      }
    },
    "shifter-aws": {
      "command": "node",
      "args": ["mcp/aws/index.js"],
      "env": {
        "PANW_SHIFTER_DEV_PROFILE": "panw-shifter-dev-workstation",
        "PANW_SHIFTER_PROD_PROFILE": "panw-shifter-prod-workstation"
      }
    }
  }
}
