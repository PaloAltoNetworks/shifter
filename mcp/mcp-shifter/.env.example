# mcp-shifter Environment Variables
# Copy to .env and fill in values

# Server
PORT=3001
CONFIG_PATH=/app/config.json

# AWS
AWS_REGION=us-east-2

# Cognito Authentication
COGNITO_USER_POOL_ID=us-east-2_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_ISSUER=https://cognito-idp.us-east-2.amazonaws.com/us-east-2_xxxxxxxxx

# RDS Database (IAM auth - no password needed)
RDS_HOSTNAME=shifter-db.cluster-xxxxx.us-east-2.rds.amazonaws.com
RDS_PORT=5432
RDS_DATABASE=shifter
RDS_USERNAME=mcp_shifter

# Logging
LOG_LEVEL=info
NODE_ENV=production
