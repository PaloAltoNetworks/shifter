# =============================================================================
# Shifter Production Environment
# =============================================================================
# Copy to .env and fill in values before running deploy.sh or make deploy.
#
# Generate secrets:
#   DJANGO_SECRET_KEY:       python3 -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
#   FIELD_ENCRYPTION_KEY:    python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   GUACAMOLE_JSON_AUTH_SECRET: python3 -c "import secrets; print(secrets.token_hex(16))"
#   DB_PASSWORD:             openssl rand -base64 32
#   GUACAMOLE_DB_PASSWORD:   openssl rand -base64 32

# -- Domain -------------------------------------------------------------------
DOMAIN_NAME=shifter.example.com

# -- Django --------------------------------------------------------------------
DJANGO_SECRET_KEY=CHANGEME
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=shifter.example.com

# -- Database (local Postgres in compose) -------------------------------------
DB_NAME=shifter
DB_USER=postgres
DB_PASSWORD=CHANGEME
DB_PORT=5432

# -- Field encryption (django-encrypted-model-fields) -------------------------
FIELD_ENCRYPTION_KEY=CHANGEME

# -- AWS -----------------------------------------------------------------------
# Leave blank to use EC2 instance profile (recommended).
# Set explicitly only for non-EC2 deployments.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-2
AWS_S3_BUCKET_NAME=

# -- Cognito OIDC --------------------------------------------------------------
OIDC_RP_CLIENT_ID=
OIDC_RP_CLIENT_SECRET=
OIDC_ISSUER_URL=
OIDC_AUTH_DOMAIN=

# -- Guacamole -----------------------------------------------------------------
GUACAMOLE_JSON_AUTH_SECRET=CHANGEME
GUACAMOLE_DB_NAME=guacamole
GUACAMOLE_DB_USER=guacamole_admin
GUACAMOLE_DB_PASSWORD=CHANGEME

# -- TLS -----------------------------------------------------------------------
# Directory containing cert.pem and key.pem (self-signed OK for internal use).
# deploy.sh will generate a self-signed cert here if none exists.
TLS_CERT_DIR=./nginx/ssl
