# Django settings (required)
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Site URL for provisioner callbacks (required)
SITE_URL=http://localhost:8000

# Database (required)
DB_NAME=shifter
DB_USER=postgres
DB_PASSWORD=your-password-here
DB_PORT=5432

# Guacamole Database (created automatically on first postgres startup)
GUACAMOLE_DB_NAME=guacamole
GUACAMOLE_DB_USER=guacamole_admin
GUACAMOLE_DB_PASSWORD=guac-local-password

# Guacamole JSON Auth (128-bit hex key, must match between Django and Guacamole)
GUACAMOLE_JSON_AUTH_SECRET=4c0b569e4c96df157c1b1fae5ef3a9d0

# Celery (optional — defaults to redis://localhost:6379/1)
# CELERY_BROKER_URL=redis://redis:6379/1
# CELERY_RESULT_BACKEND=redis://redis:6379/1

# Nginx TLS (optional — defaults to ./nginx/ssl)
TLS_CERT_DIR=./nginx/ssl
DOMAIN_NAME=localhost
