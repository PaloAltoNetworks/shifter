<powershell>
# Windows DC user_data - intentionally minimal
# All setup is handled via SSM Run Command orchestration:
#   1. BootstrapPlan: hostname + SSH configuration + reboot
#   2. DCSetupPlan: AD DS install + DC promotion + verification
#
# This script ensures access (SSH/RDP) is available even if deeper setup is delayed.

$LogFile = "C:\Windows\Temp\dc-userdata.log"

function Log-Message {
    param([string]$Message)
    $ts = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
    "$ts - $Message" | Out-File -FilePath $LogFile -Append
    Write-Host $Message
}

Log-Message "DC instance started. Setup will be orchestrated via SSM."
Log-Message "Hostname: $env:COMPUTERNAME"

# Check if this is a Domain Controller (prebaked AMI)
$isDC = $false
try {
    $dcInfo = Get-ADDomainController -ErrorAction Stop
    $isDC = $true
    Log-Message "This is a Domain Controller: $($dcInfo.Domain)"
} catch {
    Log-Message "Not a Domain Controller yet (AD cmdlets not available or not promoted)"
}

# Issue #762: the per-instance local Administrator password (used for
# pre-domain-promote access) is set by the engine provisioner after
# the host is reachable — not in user_data. After Ansible promotes the
# host to a Domain Controller, the local Administrator account becomes
# the domain Administrator and its password is replaced by
# ``DC_DOMAIN_PASSWORD`` (deployment-scoped, sourced from Secrets
# Manager via the engine provisioner ECS task). See
# shifter/engine/provisioner/plans/set_local_password_plan.py.
Log-Message "Local Administrator password will be set by the engine provisioner post-boot"

# Configure SSH key for Terminal UI (OpenSSH is baked into AMI)
$PublicKey = "{{ public_key }}"
if ($PublicKey) {
    $sshDir = "C:\\ProgramData\\ssh"
    if (!(Test-Path $sshDir)) {
        New-Item -ItemType Directory -Path $sshDir -Force | Out-Null
    }

    $PublicKey | Out-File -Encoding ascii "$sshDir\\administrators_authorized_keys"

    # Set proper permissions
    icacls "$sshDir\\administrators_authorized_keys" /inheritance:r `
        /grant "Administrators:F" /grant "SYSTEM:F" | Out-Null

    Log-Message "SSH key configured at $sshDir\\administrators_authorized_keys"
} else {
    Log-Message "No public key provided, skipping SSH key setup"
}

# Ensure OpenSSH Server is installed and running
$sshCapability = Get-WindowsCapability -Online | Where-Object Name -like 'OpenSSH.Server*'
if ($sshCapability.State -ne 'Installed') {
    Log-Message "Installing OpenSSH Server..."
    Add-WindowsCapability -Online -Name OpenSSH.Server~~~~0.0.1.0 | Out-Null
}

$sshdService = Get-Service -Name sshd -ErrorAction SilentlyContinue
if ($sshdService) {
    Start-Service sshd -ErrorAction SilentlyContinue
    Set-Service -Name sshd -StartupType Automatic
    Enable-NetFirewallRule -Name OpenSSH-Server-In-TCP -ErrorAction SilentlyContinue | Out-Null
    $sshdStatus = (Get-Service -Name sshd).Status
    Log-Message "sshd service status: $sshdStatus"
} else {
    Log-Message "WARNING: sshd service not found"
}

# Ensure RDP service is running
Log-Message "Configuring RDP (TermService)..."
try {
    Set-ItemProperty -Path "HKLM:\\System\\CurrentControlSet\\Control\\Terminal Server" `
        -Name "fDenyTSConnections" `
        -Value 0 `
        -ErrorAction SilentlyContinue
    Enable-NetFirewallRule -DisplayGroup "Remote Desktop" -ErrorAction SilentlyContinue | Out-Null
    Set-Service -Name TermService -StartupType Automatic -ErrorAction Stop
    Start-Service -Name TermService -ErrorAction Stop
    $rdpStatus = (Get-Service -Name TermService).Status
    Log-Message "TermService (RDP) status: $rdpStatus"
} catch {
    Log-Message "ERROR: Failed to start TermService: $($_.Exception.Message)"
}

# Check RDP port is listening
$rdpPort = Get-NetTCPConnection -LocalPort 3389 -State Listen -ErrorAction SilentlyContinue
if ($rdpPort) {
    Log-Message "RDP port 3389 is LISTENING"
} else {
    Log-Message "WARNING: RDP port 3389 is NOT listening"
}

# Check firewall rules for RDP
$rdpFwRule = Get-NetFirewallRule -DisplayName "*Remote Desktop*" -ErrorAction SilentlyContinue | Where-Object { $_.Enabled -eq $true }
if ($rdpFwRule) {
    Log-Message "RDP firewall rules enabled: $($rdpFwRule.Count) rules"
} else {
    Log-Message "WARNING: No enabled RDP firewall rules found"
}

# Final summary
Log-Message "=== DC user_data complete ==="
Log-Message "Password method: $(if ($isDC) { 'Set-ADAccountPassword' } else { 'net user' })"
Log-Message "SSH key: $(if ($PublicKey) { 'configured' } else { 'not provided' })"
Log-Message "Shifter setup plans will handle remaining setup (AD verification, XDR agent)"
</powershell>
