# Portal Infrastructure Configuration
# Copy to terraform.tfvars and fill in values
# DO NOT commit terraform.tfvars - sync to TF_VARS_PROD_PORTAL secret

# ------------------------------------------------------------------------------
# General
# ------------------------------------------------------------------------------

environment        = ""
aws_region         = ""
log_retention_days = 90

tags = {
  Project     = ""
  Environment = ""
  ManagedBy   = ""
}

# ------------------------------------------------------------------------------
# VPC
# ------------------------------------------------------------------------------

vpc_cidr           = ""
az_count           = 0
enable_nat_gateway = false

# ------------------------------------------------------------------------------
# RDS
# ------------------------------------------------------------------------------

db_name                  = ""
db_username              = ""
db_engine_version        = ""
db_instance_class        = ""
db_allocated_storage     = 0
db_max_allocated_storage = 0
db_multi_az              = false
db_backup_retention_days = 0
db_deletion_protection   = true
db_skip_final_snapshot   = false

# ------------------------------------------------------------------------------
# EC2
# ------------------------------------------------------------------------------

ec2_instance_type    = "t3.small"
ec2_root_volume_size = 20

# ECR values come from terraform_remote_state.foundation (no need to set here)

# ------------------------------------------------------------------------------
# ALB
# ------------------------------------------------------------------------------

domain_name       = "shifter.example.com"
app_port          = 8000
health_check_path = "/health"

# ------------------------------------------------------------------------------
# S3
# ------------------------------------------------------------------------------

user_storage_bucket = ""
