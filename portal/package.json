{
  "name": "shifter-portal",
  "private": true,
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/static/js/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "static/js/**/*.js",
      "!**/*.test.js"
    ]
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0"
  }
}
