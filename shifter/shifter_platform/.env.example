# Django settings (required)
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Site URL for provisioner callbacks (required)
SITE_URL=http://localhost:8000

# Database (required)
# Note: In docker-compose, services connect via pgbouncer (port 5432 internal)
# For direct DB access, use localhost:5432; for pgbouncer, use localhost:6432
DB_NAME=shifter
DB_USER=postgres
DB_PASSWORD=your-password-here
DB_PORT=5432
