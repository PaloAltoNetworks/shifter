# LibreChat Local Development Configuration
#
# Copy this file to .env and configure before running docker compose up
#
# Full configuration reference:
# https://www.librechat.ai/docs/configuration/dotenv

# ==============================================================================
# Server Configuration
# ==============================================================================

HOST=0.0.0.0
PORT=3080
MONGO_URI=mongodb://mongodb:27017/LibreChat

# ==============================================================================
# Authentication
# ==============================================================================

ALLOW_EMAIL_LOGIN=true
ALLOW_REGISTRATION=true
ALLOW_SOCIAL_LOGIN=false
ALLOW_SOCIAL_REGISTRATION=false
ALLOW_PASSWORD_RESET=false
ALLOW_UNVERIFIED_EMAIL_LOGIN=true

# Session Configuration
SESSION_EXPIRY=900000
REFRESH_TOKEN_EXPIRY=604800000

# ==============================================================================
# Security Secrets
# Generate with: openssl rand -hex 32
# ==============================================================================

JWT_SECRET=generate_a_random_64_char_hex_string_here
JWT_REFRESH_SECRET=generate_another_random_64_char_hex_string_here
CREDS_KEY=generate_a_third_random_64_char_hex_string_here
CREDS_IV=generate_a_random_32_char_hex_string_here

# ==============================================================================
# UI Configuration
# ==============================================================================

APP_TITLE=Shifter Chat (Local)
NO_INDEX=true

# ==============================================================================
# Features
# ==============================================================================

# Disable search for local dev (requires Meilisearch)
SEARCH=false

# Debug logging
DEBUG_LOGGING=true
DEBUG_CONSOLE=true
CONSOLE_JSON=false

# ==============================================================================
# AI Endpoints (Optional - configure as needed)
# ==============================================================================

# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# AWS Bedrock
# For local dev, set credentials. On EC2, uses instance role (no static creds).
# Uses inference profile IDs (us. prefix) required for on-demand invocation.
BEDROCK_AWS_DEFAULT_REGION=us-east-2
BEDROCK_AWS_MODELS=us.anthropic.claude-sonnet-4-5-20250929-v1:0,us.anthropic.claude-3-7-sonnet-20250219-v1:0,us.anthropic.claude-3-5-sonnet-20240620-v1:0,us.anthropic.claude-3-5-haiku-20241022-v1:0,us.anthropic.claude-3-haiku-20240307-v1:0
# BEDROCK_AWS_ACCESS_KEY_ID=...
# BEDROCK_AWS_SECRET_ACCESS_KEY=...

# Google
# GOOGLE_KEY=...

# See librechat.yaml for more advanced endpoint configuration

