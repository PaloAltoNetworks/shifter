# Snyk policy file
# Exclude test files that contain mock credentials
version: v1.25.0

exclude:
  global:
    # Test directories contain mock credentials for unit tests
    - "**/tests/**"
    - "**/test_*.py"
    - "**/conftest.py"
    - "shifter/shifter_platform/tests/**"
    - "shifter/engine/provisioner/tests/**"
    - "shifter/packer/tests/**"
    - "scripts/bootstrap/tests/**"
    - "scripts/check_layer_imports/tests/**"
    - "pulumi-provisioner/tests/**"
