<powershell>
# Windows victim instance setup script
# Minimal - all deeper setup is handled by Shifter setup plans

$ErrorActionPreference = "Stop"
$LogFile = "C:\Windows\Temp\user-data.log"

function Log-Message {
    param([string]$Message)
    $timestamp = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
    "$timestamp - $Message" | Out-File -FilePath $LogFile -Append
    Write-Host $Message
}

Log-Message "Victim Windows instance booting..."

# Issue #762: the per-instance local Administrator password is set
# by the engine provisioner via SSH (using the per-instance SSH key
# already baked into administrators_authorized_keys below) after this
# VM reaches a reachable state — not in user_data. The password value
# never appears in the rendered cloud-init payload. See
# shifter/engine/provisioner/plans/set_local_password_plan.py.
Log-Message "Local Administrator password will be set by the engine provisioner post-boot via SSH/Run Command"

# Ensure OpenSSH Server is installed
$sshCapability = Get-WindowsCapability -Online | Where-Object Name -like 'OpenSSH.Server*'
if ($sshCapability.State -ne 'Installed') {
    Log-Message "Installing OpenSSH Server..."
    Add-WindowsCapability -Online -Name OpenSSH.Server~~~~0.0.1.0 | Out-Null
}

# Configure SSH key for Terminal UI
$PublicKey = "{{ public_key }}"
if ($PublicKey) {
    $sshDir = "C:\\ProgramData\\ssh"
    if (!(Test-Path $sshDir)) {
        New-Item -ItemType Directory -Path $sshDir -Force | Out-Null
    }

    $PublicKey | Out-File -Encoding ascii "$sshDir\\administrators_authorized_keys"

    # Set proper permissions
    icacls "$sshDir\\administrators_authorized_keys" /inheritance:r `
        /grant "Administrators:F" /grant "SYSTEM:F" | Out-Null

    Log-Message "SSH key authentication configured"
} else {
    Log-Message "No public key provided, skipping SSH key setup"
}

# Ensure sshd service is running
$sshdService = Get-Service -Name sshd -ErrorAction SilentlyContinue
if ($sshdService) {
    Start-Service sshd -ErrorAction SilentlyContinue
    Set-Service -Name sshd -StartupType Automatic
    Enable-NetFirewallRule -Name OpenSSH-Server-In-TCP -ErrorAction SilentlyContinue | Out-Null
    Log-Message "sshd service started"
} else {
    Log-Message "sshd service not found"
}

# Ensure RDP service is running
Set-ItemProperty -Path "HKLM:\\System\\CurrentControlSet\\Control\\Terminal Server" `
    -Name "fDenyTSConnections" `
    -Value 0 `
    -ErrorAction SilentlyContinue
Enable-NetFirewallRule -DisplayGroup "Remote Desktop" -ErrorAction SilentlyContinue | Out-Null
Set-Service -Name TermService -StartupType Automatic -ErrorAction SilentlyContinue
Start-Service -Name TermService -ErrorAction SilentlyContinue

# All other setup (hostname, XDR) is handled by Shifter setup plans.

Log-Message "user_data complete. Shifter setup plans will handle remaining setup."
</powershell>
