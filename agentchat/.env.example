# AgentChat Environment Variables
# Copy this file to .env and fill in the values

# AWS Region for Bedrock
AWS_REGION=us-east-2

# Bedrock Access Gateway API Key
# Get from Secrets Manager: shifter-{env}-agentchat-bag-api-key
BAG_API_KEY=your-bag-api-key

# OpenWebUI PostgreSQL Database URL
# Get from Secrets Manager: shifter-{env}-portal-openwebui-db
DATABASE_URL=postgresql://user:pass@host:5432/openwebui

# Cognito Configuration
# Get from Secrets Manager: shifter-{env}-portal-cognito-agentchat
COGNITO_USER_POOL_ID=us-east-2_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_ISSUER=https://cognito-idp.us-east-2.amazonaws.com/us-east-2_xxxxxxxxx

# RDS Configuration for MCP Server
# Get from Secrets Manager: shifter-{env}-portal-db-credentials
RDS_HOSTNAME=your-rds-endpoint.rds.amazonaws.com
RDS_PORT=5432
RDS_DATABASE=portal
RDS_USERNAME=mcp_user

# OpenWebUI URL (for OAuth redirects)
WEBUI_URL=http://localhost:8080
